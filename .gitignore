# Rails credentials and secrets - never commit these
/config/master.key
/config/credentials.yml.enc

# Ignore bundler config
/.bundle

# Ignore test logs and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore storage (Active Storage files)
/storage/*
!/storage/.keep

# Ignore node_modules if any
node_modules/

# Ignore built public assets (generated by vite build)
/public/ims/assets/

# Ignore PID files
/tmp/pids/*

# Exclude schema.rb from VC because this Rails app shares a DB with the Node.js
# API. The schema.rb would include non-IMS tables from the shared DB, creating
# false dependencies. Always use db:migrate (not db:schema:load) for this app.
/db/schema.rb
